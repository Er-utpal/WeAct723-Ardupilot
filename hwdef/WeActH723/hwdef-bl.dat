# Bootloader hwdef for WeAct Studio STM32H723VGT6
# Bootloader fits in sector 0 (128KB) at 0x08000000
include ../include/minimize_common.inc
MCU STM32H7xx STM32H723xx
OSCILLATOR_HZ 25000000
FLASH_SIZE_KB 1024
APJ_BOARD_ID 1023
FLASH_BOOTLOADER_LOAD_KB 128
PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1
define BOARD_OTG_NOVBUSSENS 1
